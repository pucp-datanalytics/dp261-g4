    "# Convertir columnas que deberían ser categóricas\n",
    "categorical_columns = ['Month', 'VisitorType', 'Weekend', 'Revenue']\n",
    "for col in categorical_columns:\n",
    "    if col in df_clean.columns:\n",
    "        df_clean[col] = df_clean[col].astype('category')"
